# ============================================================
# VenomGPT — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   Linux/Mac:  cp .env.example .env
#   Windows:    copy .env.example .env
# ============================================================

# --- Z.AI Provider (required for local usage) ---

# Your Z.AI API key — get one at https://z.ai/manage-apikey/apikey-list
# Top up balance at https://z.ai/manage-apikey/billing if needed
ZAI_API_KEY=your_zai_api_key_here

# Z.AI API endpoint (OpenAI-compatible PAAS lane)
#
# Standard account (default):
#   ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
#
# GLM Coding Plan subscribers use a different PAAS endpoint:
#   ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4/
#
# Source: https://docs.z.ai/api-reference/introduction
#         https://docs.z.ai/devpack/overview
#
# NOTE: The Anthropic-compatible lane URL (https://api.z.ai/api/anthropic)
# is derived automatically from ZAI_BASE_URL. You do not need to set it separately.
# Both standard and Coding Plan accounts share the same Anthropic lane host.
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# Primary model for coding/agentic tasks (Anthropic lane)
# Recommended: glm-5.1 (flagship, SOTA coding, 200K context)
# Budget option: glm-4.7 (solid balance of quality and speed)
ZAI_MODEL=glm-5.1

# Vision model — used automatically when image content is detected (PAAS lane)
# Requires the Z.AI PAAS vision model entitlement package on the account.
# glm-4.6v is the SOTA vision model (multimodal, 128K context)
# Budget option: glm-4.6v-flash
# Without entitlement, visual tasks fail immediately with a clear error message.
ZAI_VISION_MODEL=glm-4.6v

# --- Workspace (optional) ---

# Pre-configure the workspace directory the agent reads/edits.
# If not set, configure it in the UI after startup.
# Linux/Mac example:  WORKSPACE_ROOT=/home/yourname/my-project
# Windows example:    WORKSPACE_ROOT=C:\Users\YourName\my-project
WORKSPACE_ROOT=

# --- Server Port (optional) ---

# Port for the API server.
# The root `pnpm run dev` script sets PORT=3001 for the API server
# and PORT=5173 for the frontend automatically — you do not need to
# set PORT here unless you are running services manually.
#
# PORT=3001
