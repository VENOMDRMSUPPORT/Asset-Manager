# ============================================================
# DevMind AI - Local Coding Workspace
# Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# On Windows: copy .env.example .env
# On Mac/Linux: cp .env.example .env
# ============================================================

# --- z.ai API Configuration (required) ---

# Your z.ai API key — get it from https://z.ai
ZAI_API_KEY=your_zai_api_key_here

# z.ai base URL — default is the standard endpoint
# Change this to use a different OpenAI-compatible provider (e.g. OpenAI, Anthropic via proxy, local Ollama)
ZAI_BASE_URL=https://api.z.ai/v1

# Model to use (z.ai model name)
# Default: z1-32b
ZAI_MODEL=z1-32b

# --- Workspace Configuration (optional) ---

# Pre-configure a workspace root directory so the app starts with it already set.
# This is the folder the AI agent will read and edit files in.
# If not set, you can configure it in the UI after startup.
# Example (Windows): WORKSPACE_ROOT=C:\Users\YourName\my-project
# Example (Mac/Linux): WORKSPACE_ROOT=/home/yourname/my-project
WORKSPACE_ROOT=

# --- Server Configuration ---

# Port the backend server listens on (default: 3000)
PORT=3000
