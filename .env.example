# ============================================================
# DevMind AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   Linux/Mac:  cp .env.example .env
#   Windows:    copy .env.example .env
# ============================================================

# --- Z.AI Provider (required for local usage) ---

# Your Z.AI API key — get one at https://z.ai/manage-apikey/apikey-list
# Top up balance at https://z.ai/manage-apikey/billing if needed
ZAI_API_KEY=your_zai_api_key_here

# Official Z.AI API endpoint (OpenAI-compatible)
# Do NOT use /v1 — the correct endpoint is /api/paas/v4/
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# Primary model for coding/agentic tasks
# Recommended: glm-5 (flagship, SOTA coding, 200K context)
# Budget option: glm-4.7-flash (FREE, good for testing)
ZAI_MODEL=glm-5

# Vision model — used automatically when image content is detected
# glm-4.6v is the SOTA vision model (multimodal, 128K context)
# Budget option: glm-4.6v-flash (FREE)
ZAI_VISION_MODEL=glm-4.6v

# --- Workspace (optional) ---

# Pre-configure the workspace directory the agent reads/edits.
# If not set, configure it in the UI after startup.
# Linux/Mac example:  WORKSPACE_ROOT=/home/yourname/my-project
# Windows example:    WORKSPACE_ROOT=C:\Users\YourName\my-project
WORKSPACE_ROOT=

# --- Server Port (optional) ---

# Port for the API server.
# The root `pnpm run dev` script sets PORT=3001 for the API server
# and PORT=5173 for the frontend automatically — you do not need to
# set PORT here unless you are running services manually.
#
# PORT=3001

# --- Image Generation (not yet wired) ---
# Z.AI supports image generation via GLM-Image and CogView-4 at
# POST /images/generations. This is not currently connected to the
# agent loop. The agent only uses chat completions. Future work.
